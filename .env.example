# Runtime
OMNISURG_ENV=local
OMNISURG_HTTP_PORT=8081
OMNISURG_GRPC_PORT=9081
OMNISURG_LOG_LEVEL=debug

# Database (local stack: host localhost, in compose host is postgres)
OMNISURG_DATABASE_URL=postgres://omnisurg_identity:omnisurg-local-only@localhost:5432/omnisurg_identity?sslmode=disable

# Auth
OMNISURG_JWT_SECRET=local-dev-secret-change-me
OMNISURG_JWT_TTL_MINUTES=60
OMNISURG_INTERNAL_API_KEY=local-internal-key-change-me

# Crypto: base64 of 32 random bytes. Generate with: openssl rand -base64 32
OMNISURG_KEK_BASE64=bG9jYWwtZGV2LWtlay0wMDAwMDAwMDAwMDAwMDAwMDA=

# Sentry (optional locally)
OMNISURG_SENTRY_DSN=

# CORS (comma separated)
OMNISURG_CORS_ORIGINS=http://localhost:5173,http://acme.omnisurg.localhost
